        [{ "node": "Sin teléfono - ignorar", "type": "main", "index": 0 }]
      ]
    },
    "Obtener wabaId del agente": {
      "main": [[{ "node": "Switch por evento", "type": "main", "index": 0 }]]
    },
    "Switch por evento": {
      "main": [
        [{ "node": "Mensaje cita CREADA", "type": "main", "index": 0 }],
        [{ "node": "Mensaje cita CANCELADA", "type": "main", "index": 0 }],
        [{ "node": "Mensaje cita REAGENDADA", "type": "main", "index": 0 }]
      ]
    },
    "Mensaje cita CREADA": {
      "main": [[{ "node": "Enviar WhatsApp confirmacion", "type": "main", "index": 0 }]]
    },
    "Mensaje cita CANCELADA": {
      "main": [[{ "node": "Enviar WhatsApp confirmacion", "type": "main", "index": 0 }]]
    },
    "Mensaje cita REAGENDADA": {
      "main": [[{ "node": "Enviar WhatsApp confirmacion", "type": "main", "index": 0 }]]
    },
    "Enviar WhatsApp confirmacion": {
      "main": [[{ "node": "Responder 200 a Cal.com", "type": "main", "index": 0 }]]
    }
  },
