    {
      "parameters": {
        "jsCode": "// Este nodo procesa el comentario y prepara la respuesta\nconst commentText = $input.item.json.commentText;\nconst commentId = $input.item.json.commentId;\nconst username = $input.item.json.username;\n\n// Lógica para responder comentarios\nlet responseText = '';\n\nif (commentText.toLowerCase().includes('precio')) {\n  responseText = `@${username} Te enviamos la información por DM 📩`;\n} else if (commentText.toLowerCase().includes('disponible')) {\n  responseText = `@${username} ¡Sí está disponible! Te escribimos al DM con los detalles ✅`;\n} else if (commentText.toLowerCase().includes('gracias') || commentText.includes('❤️')) {\n  responseText = `@${username} ¡Gracias a ti! 🙌`;\n} else {\n  responseText = `@${username} ¡Gracias por tu comentario! Te respondemos por mensaje directo.`;\n}\n\nreturn [{\n  json: {\n    commentId: commentId,\n    responseText: responseText,\n    originalComment: commentText,\n    username: username\n  }\n}];"
      },
