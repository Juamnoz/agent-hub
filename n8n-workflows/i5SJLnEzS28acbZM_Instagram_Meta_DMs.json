    {
      "parameters": {
        "jsCode": "// Extraer el evento de Meta\nconst entry = $input.item.json.body.entry;\n\nif (!entry || entry.length === 0) {\n  return [];\n}\n\nconst results = [];\n\nfor (const item of entry) {\n  // Detectar si es mensaje (DM)\n  if (item.messaging) {\n    for (const msg of item.messaging) {\n      if (msg.message) {\n        results.push({\n          json: {\n            eventType: 'message',\n            platform: 'instagram',\n            senderId: msg.sender.id,\n            recipientId: msg.recipient.id,\n            messageId: msg.message.mid,\n            messageText: msg.message.text || '',\n            timestamp: msg.timestamp,\n            pageId: item.id\n          }\n        });\n      }\n    }\n  }\n  \n  // Detectar si es comentario\n  if (item.changes) {\n    for (const change of item.changes) {\n      if (change.field === 'comments' && change.value.item === 'comment') {\n        results.push({\n          json: {\n            eventType: 'comment',\n            platform: 'instagram',\n            commentId: change.value.id,\n            postId: change.value.media.id,\n            commentText: change.value.text,\n            userId: change.value.from.id,\n            username: change.value.from.username,\n            timestamp: change.value.created_time,\n            pageId: item.id\n          }\n        });\n      }\n    }\n  }\n}\n\nreturn results;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        976,
        224
      ],
      "id": "e1f23569-433d-4405-b377-017ba91b147f",
      "name": "Parsear Evento"
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.eventType }}",
              "operation": "equals",
              "value2": "message"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        1200,
        224
      ],
      "id": "3c6b3579-a107-440c-b52e-ef605ea3f6b9",
      "name": "¿Es Mensaje o Comentario?"
    },
    {
      "parameters": {
        "jsCode": "// Este nodo procesa el mensaje entrante y prepara la respuesta\nconst messageText = $input.item.json.messageText;\nconst senderId = $input.item.json.senderId;\nconst pageId = $input.item.json.pageId;\n\n// Aquí puedes agregar lógica de IA o reglas de negocio\nlet responseText = '';\n\nif (messageText.toLowerCase().includes('hola')) {\n  responseText = '¡Hola! 👋 Gracias por escribirnos. ¿En qué podemos ayudarte?';\n} else if (messageText.toLowerCase().includes('precio')) {\n  responseText = 'Con gusto te compartimos nuestros precios. ¿Qué producto te interesa?';\n} else if (messageText.toLowerCase().includes('horario')) {\n  responseText = 'Nuestro horario de atención es de Lunes a Viernes de 9am a 6pm.';\n} else {\n  responseText = 'Gracias por tu mensaje. Un asesor te responderá pronto.';\n}\n\nreturn [{\n  json: {\n    senderId: senderId,\n    pageId: pageId,\n    responseText: responseText,\n    originalMessage: messageText\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1424,
        112
      ],
      "id": "45441198-710f-41f5-bef6-c25305a8a2d3",
      "name": "Procesar Mensaje"
    },
