    {
      "id": "appt-classify-intent-001",
      "name": "Clasificar Intent Cita",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 300],
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{ $credentials.openAiApi.apiKey }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"Eres un clasificador de intenciones. Analiza el mensaje del usuario y responde ÚNICAMENTE con una de estas palabras exactas (sin puntuación ni explicación):\\n- AGENDAR (si el usuario quiere crear, pedir, reservar o agendar una cita)\\n- CANCELAR (si el usuario quiere cancelar, eliminar o anular una cita existente)\\n- CONSULTAR (si el usuario pregunta sobre disponibilidad, horarios, fechas o citas existentes)\\n- OTRO (cualquier otro tipo de mensaje)\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"{{ $json.message }}\"\n    }\n  ],\n  \"max_tokens\": 10,\n  \"temperature\": 0\n}",
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "openai-header-cred",
          "name": "OpenAI Header"
        }
      }
    },
