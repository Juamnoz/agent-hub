              "type": "string"
            },
            {
              "id": "intent-006",
              "name": "wabaId",
              "value": "={{ $('Preparar contexto').item.json.wabaId }}",
              "type": "string"
            },
            {
              "id": "intent-007",
              "name": "agent_id",
